{
  "extends": ["config:base", "helpers:pinGitHubActionDigests"],
  "prConcurrentLimit": 2,
  "ignoreDeps": ["eslint-plugin-verdaccio", "husky", "lint-staged"],
  "baseBranches": ["main"],
  "major": true,
  "labels": ["bot: dependencies"],
  "packageRules": [
    {
      "packageNames": ["typescript"],
      "allowedVersions": "3.9.10"
    },
    {
      "packageNames": ["@types/node"],
      "allowedVersions": "14.18.0"
    },
    {
      "packageNames": ["lowdb"],
      "allowedVersions": "1.0.0"
    },
    {
      "packageNames": ["node-fetch"],
      "allowedVersions": "< 3.0.0"
    },
    {
      "matchPackagePatterns": [
        "@trivago/*",
        "prettier",
        "eslint-*",
        "eslint",
        "stylelint",
        "@typescript-eslint/*"
      ],
      "matchUpdateTypes": ["minor", "patch", "major"],
      "groupName": "all linting dependencies",
      "groupSlug": "all-linting",
      "baseBranchList": ["main"]
    },
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all core dependencies",
      "groupSlug": "all-core",
      "extends": [":semanticCommitTypeAll(fix)"]
    }
  ],
  "pinVersions": false
}
