{
  "extends": "../../tsconfig.reference.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "declaration": true,
    "strict": true,
    "importsNotUsedAsValues": "remove",
    "outDir": "lib",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src/*.ts", "tests/**/*.ts", "types/*.d.ts"],
  "references": [
    {
      "path": "../types"
    }
  ]
}
